{
  "name": "vendure-pi",
  "version": "1.0.0",
  "description": "Pi agent extension for Vendure e-commerce management. Connect to your Vendure instance and manage products, orders, customers, and more through natural language. Requires vendure-mcp-graphql.",
  "keywords": [
    "pi-package",
    "vendure",
    "ecommerce",
    "graphql"
  ],
  "type": "module",
  "pi": {
    "extensions": [
      "./extensions"
    ],
    "skills": [
      "./skills"
    ],
    "prompts": [
      "./prompts"
    ]
  },
  "peerDependencies": {
    "@mariozechner/pi-ai": "*",
    "@mariozechner/pi-agent-core": "*",
    "@mariozechner/pi-coding-agent": "*",
    "typebox": "*"
  },
  "dependencies": {
    "vendure-mcp-graphql": "^1.0.0",
    "@modelcontextprotocol/sdk": "^1.0.0"
  },
  "bundledDependencies": [
    "vendure-mcp-graphql"
  ]
}
